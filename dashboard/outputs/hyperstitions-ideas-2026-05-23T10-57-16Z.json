{
  "root": "main-card",
  "state": {},
  "elements": {
    "main-card": {
      "type": "Card",
      "props": {
        "title": "Hyperstitions Idea — 2026-05-23"
      },
      "children": [
        "main-stack"
      ]
    },
    "main-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "question",
        "sep1",
        "coordination-section",
        "sep2",
        "why-now-section",
        "sep3",
        "resolution-section",
        "sep4",
        "scores-section",
        "sep5",
        "link-section"
      ]
    },
    "question": {
      "type": "Text",
      "props": {
        "text": "Will MiroShark receive 10 merged PRs from community contributors (non-bot, non-core-team) by August 1, 2026?",
        "variant": "lead"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "coordination-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "coord-title",
        "coord-text1",
        "coord-text2",
        "coord-text3",
        "ideas-text"
      ]
    },
    "coord-title": {
      "type": "Heading",
      "props": {
        "text": "The Coordination Play",
        "level": "h3"
      }
    },
    "coord-text1": {
      "type": "Text",
      "props": {
        "text": "MiroShark has 243 forks and exactly one external contributor. An AI agent ships a feature every single day, but it cannot recruit humans, review community code, or build the social proof that turns forkers into contributors."
      }
    },
    "coord-text2": {
      "type": "Text",
      "props": {
        "text": "This market turns every fork into a latent bet — each merged PR moves the needle, and each person who sees the counter thinks \"I could be one of those ten.\""
      }
    },
    "coord-text3": {
      "type": "Text",
      "props": {
        "text": "Repo-actions already surfaced beginner-friendly ideas (tag system, discussion threads, MCP tool server) that need human hands."
      }
    },
    "ideas-text": {
      "type": "Text",
      "props": {
        "text": "Key metrics: 243 forks, 1 external contributor, daily AI-shipped features",
        "variant": "muted"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "why-now-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "why-now-title",
        "why-now-text1",
        "why-now-text2"
      ]
    },
    "why-now-title": {
      "type": "Heading",
      "props": {
        "text": "Why Now",
        "level": "h3"
      }
    },
    "why-now-text1": {
      "type": "Text",
      "props": {
        "text": "@teifurin submitted the first-ever community PR last week (Neo4j security fix, PR #89) — breaking the seal on a project that had 242 forks and zero outside contributors."
      }
    },
    "why-now-text2": {
      "type": "Text",
      "props": {
        "text": "The ratio of 22 AI-built features to 1 human PR is the kind of absurd stat that makes developers want to change it."
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "resolution-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "resolution-title",
        "resolution-text",
        "verification-text"
      ]
    },
    "resolution-title": {
      "type": "Heading",
      "props": {
        "text": "Resolution",
        "level": "h3"
      }
    },
    "resolution-text": {
      "type": "Text",
      "props": {
        "text": "YES if ≥10 PRs authored by GitHub users other than @aaronjmars and @aeonframework are merged into aaronjmars/MiroShark by 2026-08-01T00:00:00Z."
      }
    },
    "verification-text": {
      "type": "Text",
      "props": {
        "text": "Verified via git log --merges on the main branch.",
        "variant": "caption"
      }
    },
    "sep4": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "scores-section": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "score-reflexivity",
        "score-viral"
      ]
    },
    "score-reflexivity": {
      "type": "Stat",
      "props": {
        "label": "Reflexivity",
        "value": "4/5"
      }
    },
    "score-viral": {
      "type": "Stat",
      "props": {
        "label": "Viral",
        "value": "4/5"
      }
    },
    "sep5": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "link-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "coming-soon-text",
        "hyperstitions-link"
      ]
    },
    "coming-soon-text": {
      "type": "Text",
      "props": {
        "text": "Soon on",
        "variant": "caption"
      }
    },
    "hyperstitions-link": {
      "type": "Link",
      "props": {
        "label": "hyperstitions.com",
        "href": "https://www.hyperstitions.com/"
      }
    }
  }
}
