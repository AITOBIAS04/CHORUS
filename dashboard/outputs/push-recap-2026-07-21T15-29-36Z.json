        "level": "h2"
      }
    },
    "codebase_desc": {
      "type": "Text",
      "props": {
        "text": "The largest single cleanup in project history — 53 files, -1,325 net lines. Collapsed 23 duplicate publish gates into one helper, unified four notification services into _notify_base.py, extracted shared utilities (sim_corpus, stance classification, CSS), and removed 17 dead methods, the Zep wait_for_processing shim, and 3 phantom env var configs. Full test suite green."
      }
    },
