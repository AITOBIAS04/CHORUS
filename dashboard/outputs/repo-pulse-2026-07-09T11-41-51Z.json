{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse"
      },
      "children": [
        "date-text",
        "sep1",
        "repo-heading",
        "sep2",
        "stats-stack",
        "sep3",
        "stargazers-alert"
      ]
    },
    "date-text": {
      "type": "Text",
      "props": {
        "text": "2026-07-09",
        "variant": "muted"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "repo-heading": {
      "type": "Heading",
      "props": {
        "text": "aaronjmars/MiroShark",
        "level": "h2"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stats-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "stars-stat",
        "forks-stat"
      ]
    },
    "stars-stat": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "1,357",
        "delta": "+1",
        "trend": "up"
      }
    },
    "forks-stat": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "286",
        "delta": "+0",
        "trend": "neutral"
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stargazers-alert": {
      "type": "Alert",
      "props": {
        "title": "New stargazers",
        "message": "username unavailable — stargazers API returned 403",
        "type": "warning"
      }
    }
  }
}
