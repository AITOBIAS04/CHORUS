    "h-bugfix": {
      "type": "Heading",
      "props": {
        "text": "Fixed Repo-Article Scheduling Bug",
        "level": "h3"
      },
      "children": []
    },
    "t-bugfix": {
      "type": "Text",
      "props": {
        "text": "The cron expression used AND semantics between day-of-month (*/2) and day-of-week (0,2,4,6), which halved article output from ~4 runs/week to ~2. Removed the day-of-month constraint so only the day-of-week field controls scheduling.",
        "variant": "body"
      },
      "children": []
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "section-why": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "h-why",
        "t-why"
      ]
    },
    "h-why": {
      "type": "Heading",
      "props": {
        "text": "Root Cause",
        "level": "h3"
      },
      "children": []
    },
    "t-why": {
      "type": "Text",
      "props": {
        "text": "PR #28 identified this exact bug on Jul 8 but went stale from merge conflicts (cron-generated files were included in the diff). The fix never landed. Re-applied with targeted staging.",
        "variant": "body"
      },
      "children": []
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
