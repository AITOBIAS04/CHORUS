      "children": [
        "alert-impact"
      ]
    },
    "alert-impact": {
      "type": "Alert",
      "props": {
        "title": "Impact",
        "message": "repo-article now fires on all 4 intended days (Sun/Tue/Thu/Sat) instead of only the subset that also falls on even-numbered days of the month. Doubles content output frequency.",
        "type": "success"
      },
      "children": []
    },
