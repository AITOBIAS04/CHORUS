        "level": "h3"
      },
      "children": []
    },
    "t-changes-file": {
      "type": "Text",
      "props": {
        "text": "aeon.yml: repo-article schedule",
        "variant": "muted"
      },
      "children": []
    },
    "t-changes-from": {
      "type": "Text",
      "props": {
        "text": "From: '0 16 */2 * 0,2,4,6'",
        "variant": "body"
      },
      "children": []
    },
    "t-changes-to": {
      "type": "Text",
      "props": {
        "text": "To: '0 16 * * 0,2,4,6'",
        "variant": "body"
      },
      "children": []
