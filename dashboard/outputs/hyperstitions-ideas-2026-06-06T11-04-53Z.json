      "props": {
        "text": "Will MiroShark reach the Hacker News front page by July 15, 2026?",
        "level": "h2"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {}
    },
    "text_coordination_intro": {
      "type": "Text",
      "props": {
        "text": "The coordination play: Nobody can upvote what nobody submits.",
        "variant": "lead"
      }
    },
    "text_coordination_details": {
      "type": "Text",
      "props": {
        "text": "MiroShark has 1,235 stars, 32 composable surfaces, three languages, and a top-10 oosmetrics ranking in Reinforcement Learning — all without a single front-page HN moment. Someone needs to write the Show HN post. Others need to show up in the first hour and upvote. A comment section full of people who actually ran a simulation seals it."
      }
    },
    "text_ai_cannot": {
      "type": "Text",
      "props": {
        "text": "An AI agent cannot submit, cannot upvote, and cannot seed organic discussion — this is pure human coordination.",
        "variant": "muted"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {}
    },
    "heading_why_now": {
      "type": "Heading",
      "props": {
        "text": "Why now",
        "level": "h2"
