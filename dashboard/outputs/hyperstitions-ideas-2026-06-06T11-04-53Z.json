    },
    "text_why_now": {
      "type": "Text",
      "props": {
        "text": "The project just cracked the oosmetrics top 10 for RL while shipping its 32nd share surface and third language in three days. The feature density is now absurd relative to its exposure. First green token candle in a week suggests sentiment may be turning. The window between \"undiscovered\" and \"discovered\" is closing — and HN is how it closes."
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {}
    },
    "heading_resolution": {
