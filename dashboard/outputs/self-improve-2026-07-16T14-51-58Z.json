        "text": "Agent Self-Improvement — 2026-07-16",
        "level": "h2"
      }
    },
    "alert-1": {
      "type": "Alert",
      "props": {
        "title": "WebSearch Query Overuse",
        "message": "fetch-tweets skill runs 6–7 WebSearch queries each execution when XAI_API_KEY is not set. For 10 consecutive days (Jul 7–16), every query has returned zero fresh tweets — the WebSearch fallback consistently surfaces months-old high-engagement content that gets filtered by the freshness gate.",
        "type": "warning"
      }
    },
    "sep-1": {
      "type": "Separator",
      "props": {}
    },
    "solution-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "heading-2",
        "text-1"
      ]
    },
    "heading-2": {
      "type": "Heading",
      "props": {
        "text": "Solution: Cap at 3 Queries",
        "level": "h3"
      }
    },
    "text-1": {
      "type": "Text",
      "props": {
        "text": "Adding a hard cap of 3 queries per run cuts wasted compute by ~50% with no output loss. The 3 queries follow a diversity strategy: one broad, one date-constrained, one variant."
      }
    },
    "sep-2": {
      "type": "Separator",
      "props": {}
    },
    "context-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
