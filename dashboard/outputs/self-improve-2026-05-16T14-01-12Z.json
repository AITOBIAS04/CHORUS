{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Agent Self-Improvement — 2026-05-16",
        "description": "Fixed agent monitoring data quality — two issues that have been degrading self-awareness for 2+ weeks."
      },
      "children": [
        "why-section",
        "sep1",
        "whatchanged-section",
        "sep2",
        "impact-section",
        "sep3",
        "pr-link"
      ]
    },
    "why-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading-why",
        "why-text1",
        "why-text2"
      ]
    },
    "heading-why": {
      "type": "Heading",
      "props": {
        "text": "Why",
        "level": "h3"
      }
    },
    "why-text1": {
      "type": "Text",
      "props": {
        "text": "Every heartbeat run since May 1 has logged \"auto-dispatch blocked, manual dispatch needed\" (always 403 — wrong permissions)."
      }
    },
    "why-text2": {
      "type": "Text",
      "props": {
        "text": "Meanwhile, ALL skill success rates showed 1–7% despite being 100% healthy — poisoned by the Apr 16–30 auth outage accumulating 200–300+ failures per skill."
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "whatchanged-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading-whatchanged",
        "whatchanged-text1",
        "whatchanged-text2"
      ]
    },
    "heading-whatchanged": {
      "type": "Heading",
      "props": {
        "text": "What changed",
        "level": "h3"
      }
    },
    "whatchanged-text1": {
      "type": "Text",
      "props": {
        "text": "skills/heartbeat/SKILL.md: Added permission preflight check before auto-dispatch. When blocked (actions: read only), defers to scheduler instead of repeating failed attempts."
      }
    },
    "whatchanged-text2": {
      "type": "Text",
      "props": {
        "text": "memory/cron-state.json: Reset poisoned counters for all 14 healthy skills. Success rates now show 1.0 (100%) instead of 0.01–0.07 (1–7%)."
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "impact-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading-impact",
        "impact-text1",
        "impact-text2",
        "impact-text3"
      ]
    },
    "heading-impact": {
      "type": "Heading",
      "props": {
        "text": "Impact",
        "level": "h3"
      }
    },
    "impact-text1": {
      "type": "Text",
      "props": {
        "text": "Monitoring data reflects actual health."
      }
    },
    "impact-text2": {
      "type": "Text",
      "props": {
        "text": "Heartbeat stops creating false alert noise."
      }
    },
    "impact-text3": {
      "type": "Text",
      "props": {
        "text": "Downstream skills (skill-leaderboard, skill-health) will see accurate success rates."
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "pr-link": {
