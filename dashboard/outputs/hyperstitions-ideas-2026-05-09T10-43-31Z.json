    "heading_coordination": {
      "type": "Heading",
      "props": {
        "text": "The coordination play",
        "level": "h3"
      },
      "children": []
    },
    "text_coordination": {
      "type": "Text",
      "props": {
        "text": "MiroShark just shipped Reproducibility Config Export (PR #75), making every simulation run citable with a config hash, version lock, and one-click reproduce.json. But the infrastructure means nothing without humans who actually use it — researchers designing multi-agent studies, students building thesis experiments, labs running belief drift analyses. The market's existence puts MiroShark on the radar of anyone browsing prediction markets who also publishes. A single citation bootstraps credibility that no amount of GitHub stars can replicate.",
        "variant": "body"
      },
      "children": []
    },
    "separator1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "heading_why": {
      "type": "Heading",
      "props": {
        "text": "Why now",
        "level": "h3"
      },
      "children": []
    },
    "text_why": {
      "type": "Text",
      "props": {
        "text": "PR #75 Reproducibility Config Export merged May 8, closing the last gap between \"cool demo\" and \"citable instrument.\" The May 8 project-lens article (\"AI's Reproducibility Crisis Isn't Technical. It's a Choice.\") explicitly framed MiroShark's audit trail as a regulatory and academic template. Jupyter Notebook Export is built and waiting. The toolchain for academic use is complete — what's missing is the humans.",
        "variant": "body"
      },
      "children": []
    },
    "separator2": {
      "type": "Separator",
