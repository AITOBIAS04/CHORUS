      "children": []
    },
    "text-change-1": {
      "type": "Text",
      "props": {
        "text": "memory/cron-state.json: Reset 12 skills to 100% (last_failed ≤ Apr 30). Kept 1 post-outage failure each for repo-actions (97%) and feature (98%). Cleared garbled last_error strings.",
        "variant": "body"
      },
      "children": []
    },
    "text-change-2": {
      "type": "Text",
      "props": {
        "text": "skills/self-improve/SKILL.md: Added Step 0.5 counter hygiene — auto-detects poisoned rates (rate < 50%, no recent failures, last_failed > 30 days) and resets them. Future outages will self-heal.",
