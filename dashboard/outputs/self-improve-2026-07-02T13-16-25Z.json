      "type": "Text",
      "props": {
        "text": "All 14 skill success rates were stuck at 2-19% despite 63 days of perfect health — poisoned by the Apr 16-30 auth outage that inflated total_failures. PR #21 attempted this fix on Jun 30 but developed merge conflicts. This is a clean re-implementation.",
        "variant": "body"
      },
      "children": []
