    },
    "heading-why": {
      "type": "Heading",
      "props": {
        "text": "Why",
        "level": "h3"
      },
      "children": []
    },
    "text-why": {
      "type": "Text",
      "props": {
        "text": "Poisoned success_rate values (e.g. heartbeat at 19%, weekly-shiplog at 2%) make health monitoring unreliable — skill-health, skill-leaderboard, and heartbeat cannot distinguish real degradation from legacy noise.",
        "variant": "body"
      },
      "children": []
