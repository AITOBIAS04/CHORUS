{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse"
      },
      "children": [
        "repo-name",
        "sep-1",
        "stats-section",
        "sep-2",
        "stargazers-section"
      ]
    },
    "repo-name": {
      "type": "Heading",
      "props": {
        "text": "aaronjmars/MiroShark",
        "level": "h2"
      },
      "children": []
    },
    "sep-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "stats-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "stats-heading",
        "stats-stack"
      ]
    },
    "stats-heading": {
      "type": "Heading",
      "props": {
        "text": "Statistics",
        "level": "h3"
      },
      "children": []
    },
    "stats-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "stars-stat",
        "forks-stat"
      ]
    },
    "stars-stat": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "1,134",
        "delta": "+3",
        "trend": "up"
      },
      "children": []
    },
    "forks-stat": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "224",
        "delta": "+0",
        "trend": "neutral"
      },
      "children": []
    },
    "sep-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "stargazers-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "stargazers-heading",
        "stargazers-list"
      ]
    },
    "stargazers-heading": {
      "type": "Heading",
      "props": {
        "text": "New Stargazers",
        "level": "h3"
      },
      "children": []
    },
    "stargazers-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "stargazer-1",
        "stargazer-2",
        "stargazer-3"
      ]
    },
    "stargazer-1": {
      "type": "Link",
      "props": {
        "label": "AIGoose",
        "href": "https://github.com/AIGoose"
      },
      "children": []
    },
    "stargazer-2": {
      "type": "Link",
      "props": {
        "label": "ajmz",
        "href": "https://github.com/ajmz"
      },
      "children": []
    },
    "stargazer-3": {
      "type": "Link",
      "props": {
        "label": "Zniniz",
        "href": "https://github.com/Zniniz"
      },
      "children": []
    }
  }
}
