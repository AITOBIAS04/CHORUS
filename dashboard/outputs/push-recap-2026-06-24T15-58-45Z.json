    "text_feature3_desc": {
      "type": "Text",
      "props": {
        "text": "Split xai=skip into xai=quiet (prefetch worked, market is just quiet) vs xai=skip (no data fetched). Five days of ambiguous xai=skip after the Jun 22 prefetch fix are now a readable signal.",
        "variant": "body"
      },
      "children": []
