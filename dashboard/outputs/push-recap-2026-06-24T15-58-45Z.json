    },
    "text_feature1_desc": {
      "type": "Text",
      "props": {
        "text": "New `wait` command blocks until a simulation finishes, enabling scripted pipelines like `wait \"$SIM\" && report \"$SIM\"`. Tunable interval/timeout, transient network errors treated as retryable. Exits 0/1/2 for completed/failed/timeout. Full bilingual docs.",
        "variant": "body"
      },
      "children": []
    },
    "feature_2": {
      "type": "Stack",
      "props": {
