    "gap-1": {
      "type": "Text",
      "props": {
        "text": "token-report: last ran Jun 3 (now 14h overdue)",
        "variant": "body"
      }
    },
    "gap-2": {
      "type": "Text",
      "props": {
        "text": "fetch-tweets: last ran Jun 3 (now 13.5h overdue)",
        "variant": "body"
      }
    },
    "gap-3": {
      "type": "Text",
      "props": {
        "text": "repo-article: hasn't run since May 30 (5 days)",
        "variant": "body"
      }
