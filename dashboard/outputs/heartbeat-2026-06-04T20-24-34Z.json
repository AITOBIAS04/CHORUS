      "type": "Badge",
      "props": {
        "text": "feature",
        "variant": "default"
      }
    },
    "badge-actions": {
      "type": "Badge",
      "props": {
        "text": "repo-actions",
        "variant": "default"
      }
    },
    "badge-recap": {
      "type": "Badge",
      "props": {
        "text": "push-recap",
        "variant": "default"
