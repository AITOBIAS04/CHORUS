    "description-text": {
      "type": "Text",
      "props": {
        "text": "MiroShark PR #254 merged today: eight AI research agents audited the codebase across eight dimensions of cleanup, touching 53 files and deleting 1,325 net lines. Three of the eight dimensions produced zero commits because nothing passed the safety bar — and six real bugs were found but deliberately left for separate PRs. The project gained 53 stars this week to 1,413 while social mentions stayed at zero for 15 straight days.",
        "variant": "body"
      },
      "children": []
    },
