    "heading_why": {
      "type": "Heading",
      "props": {
        "text": "Why this matters:",
        "level": "h3"
      },
      "children": []
    },
    "text_why1": {
      "type": "Text",
      "props": {
        "text": "The existing Interaction Network graph tracks action-level edges — who replied to, quoted, or liked whom. But textual mentions are a qualitatively different signal: an agent can be talked about constantly without ever being directly interacted with, and vice versa. For researchers studying information diffusion and agenda-setting ('which agent set the narrative?'), mention frequency is the missing primitive."
      },
      "children": []
    },
    "text_why2": {
      "type": "Text",
      "props": {
        "text": "This was idea #3 from the June 6 repo-actions analysis, following Cross-Platform Sentiment Divergence and Per-Round Confidence Trajectory."
      },
      "children": []
    },
