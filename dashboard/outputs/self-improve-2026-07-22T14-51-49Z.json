    "why_heading": {
      "type": "Heading",
      "props": {
        "text": "Why",
        "level": "h3"
      }
    },
    "why_context": {
      "type": "Text",
      "props": {
        "text": "This is the third time repo-article has run twice in a day."
      }
    },
    "why_history": {
      "type": "Text",
      "props": {
        "text": "PR #37 attempted this fix on Jul 20 but went DIRTY from volatile files in the commit.",
        "variant": "caption"
      }
    },
