    "summary_text": {
      "type": "Text",
      "props": {
        "text": "Merged PR #36 (skill-leaderboard early exit). New improvement: added same-day rerun dedup to repo-article skill."
      }
    },
    "sep_1": {
      "type": "Separator",
      "props": {}
    },
    "problem_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
