        "problem_heading",
        "problem_text",
        "problem_detail"
      ]
    },
    "problem_heading": {
      "type": "Heading",
      "props": {
        "text": "Problem",
        "level": "h3"
      }
    },
    "problem_text": {
      "type": "Text",
      "props": {
        "text": "On Jul 21, repo-article ran twice and the second run silently overwrote the first article — a dead-code audit piece was replaced by an MCP security article."
      }
    },
    "problem_detail": {
      "type": "Text",
      "props": {
        "text": "The skill now checks for an existing log entry before running. If an article was already written today and no specific angle was requested, it exits early instead of re-analyzing and overwriting.",
        "variant": "caption"
      }
    },
    "sep_2": {
      "type": "Separator",
      "props": {}
    },
    "solution_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "solution_heading",
        "solution_text"
      ]
    },
    "solution_heading": {
      "type": "Heading",
      "props": {
        "text": "Solution",
        "level": "h3"
      }
    },
    "solution_text": {
      "type": "Text",
      "props": {
        "text": "Added same-day rerun dedup gate — checks for existing Repo Article log entry and stops if already reported. This pattern is also used by push-recap and repo-pulse."
      }
    },
    "sep_3": {
      "type": "Separator",
      "props": {}
