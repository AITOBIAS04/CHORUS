    "pr1_link": {
      "type": "StoryLink",
      "props": {
        "title": "Server-Side Surface Catalog Filtering",
        "href": "https://github.com/AITOBIAS04/CHORUS/pull/157",
        "source": "MiroShark PR #157"
      }
    },
    "pr1_text": {
      "type": "Text",
      "props": {
        "text": "The /api/surfaces.json endpoint now accepts an optional ?type=<category> query param, letting integrators fetch just one of the 7 surface categories server-side instead of pulling the full 37-surface catalog. Per-category ETags prevent cache collisions. Unknown types return 400 with the valid set. 8 new tests, OpenAPI spec and docs updated. Fully backward-compatible.",
        "variant": "body"
      }
    },
    "sep_1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "pr_section_2": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "pr2_link",
        "pr2_text"
      ]
    },
    "pr2_link": {
      "type": "StoryLink",
      "props": {
        "title": "Pre-Ship Validation for Feature Skill",
        "href": "https://github.com/AITOBIAS04/CHORUS/pull/60",
        "source": "miroshark-aeon PR #60"
      }
    },
    "pr2_text": {
      "type": "Text",
      "props": {
        "text": "The autonomous feature skill was cloning repos into /tmp where the sandbox blocks code execution — every feature PR shipped without running its test suite. Now clones into workspace-relative .feature-build/ where exec is permitted, and adds an explicit \"validate before shipping\" step. Triggered by today's MiroShark #157 shipping 8 unrun tests.",
        "variant": "body"
      }
    },
    "sep_2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "pr_section_3": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "pr3_heading",
        "pr3_text"
      ]
    },
    "pr3_heading": {
      "type": "Heading",
      "props": {
        "text": "Inbound Message Handling Disabled",
        "level": "h3"
      }
    },
    "pr3_text": {
      "type": "Text",
      "props": {
        "text": "TG/Discord/Slack message collection and dispatch turned off at operator request. Cron scheduler unaffected — all scheduled skills keep running. Reversible via two inline comments.",
        "variant": "body"
      }
    },
    "sep_3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
