    "text_intro": {
      "type": "Text",
      "props": {
        "text": "Added dedup guard and duplicate PR cleanup to the self-improve skill. On Jul 4, the scheduler triggered self-improve twice in one day, creating duplicate PRs #24 and #25 — both attempting the same cron-state counter fix. Both developed merge conflicts and sat as DIRTY clutter for 2 days."
      }
    },
