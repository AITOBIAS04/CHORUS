      "type": "Heading",
      "props": {
        "text": "Why",
        "level": "h3"
      }
    },
    "text_why": {
      "type": "Text",
      "props": {
        "text": "Scheduler double-trigger on Jul 4 (13:01 + 14:49 UTC) with no guard against creating a second PR. The skill ran the same analysis twice and opened two identical PRs."
      }
    },
