    "heading_main": {
      "type": "Heading",
      "props": {
        "text": "Half of Open-Source AI Projects Never Reach Production. One Spent Last Week Doing Nothing But Maintenance.",
        "level": "h2"
      }
    },
    "text_para1": {
      "type": "Text",
      "props": {
        "text": "Mozilla's 2026 State of Open Source AI report says 79% of developers use open models but only 51% deploy in production — the gap is maintenance, not features."
      }
    },
    "text_para2": {
      "type": "Text",
      "props": {
        "text": "MiroShark shipped zero new features last week: two same-day CVE patches, 1,325 lines of dead code removed, full dependency sweep. Fifty stars added anyway."
      }
    },
    "text_para3": {
      "type": "Text",
      "props": {
        "text": "When 93% of codebases contain zombie components, operational discipline is the moat."
      }
    },
    "separator_main": {
      "type": "Separator",
      "props": {}
    },
    "grid_stats": {
