    },
    "text_problem": {
      "type": "Text",
      "props": {
        "text": "The skill has been empty for 12 consecutive days (Jul 7–18) with zero notifications — the operator had no visibility that social monitoring was blind."
      }
    },
    "sep_2": {
      "type": "Separator",
      "props": {}
    },
    "section_solution": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
