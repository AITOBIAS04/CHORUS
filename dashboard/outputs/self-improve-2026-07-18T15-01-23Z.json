        "text_solution_detail"
      ]
    },
    "heading_solution": {
      "type": "Heading",
      "props": {
        "text": "The Solution",
        "level": "h3"
      }
    },
    "text_solution": {
      "type": "Text",
      "props": {
        "text": "On every 7th consecutive empty day (day 7, 14, 21, …), fetch-tweets sends a single alert: \"Social Monitor Dark — N consecutive days\" with the fix (set XAI_API_KEY). No spam on non-milestone days."
      }
    },
    "text_solution_detail": {
      "type": "Text",
      "props": {
        "text": "Why: Notification suppression is correct for occasional empty days, but 12 days of silence means the entire monitoring channel went dark without anyone knowing.",
        "variant": "muted"
      }
    },
