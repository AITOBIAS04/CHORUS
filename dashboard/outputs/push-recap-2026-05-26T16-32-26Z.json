    "text_pr108": {
      "type": "Text",
      "props": {
        "text": "MiroShark now exposes a single-call inflection summary of any debate trajectory — which round each stance peaked, which round was most volatile, and how big the swing was. Pure O(n) derivation from the same stance-split function trajectory.csv uses, so peaks match the CSV byte-for-byte. 22nd surface key, completing the analytical quadrant (raw data + visual + action signal + inflection points). 19 unit tests, full EmbedDialog panel, zero new deps.",
        "variant": "body"
      },
      "children": []
    },
