    "card-heartbeat": {
      "type": "Card",
      "props": {
        "title": "Heartbeat 2026-06-21"
      },
      "children": [
        "alert-issues",
        "sep-1",
        "section-missing",
        "sep-2",
        "alert-dispatch",
        "sep-3",
        "section-pr",
        "sep-4",
        "section-nominal",
        "sep-5",
