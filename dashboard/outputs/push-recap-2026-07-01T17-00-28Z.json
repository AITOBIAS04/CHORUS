    "card": {
      "type": "Card",
      "props": {
        "title": "Push Recap — 2026-07-01"
      },
      "children": [
        "main_stack"
      ]
    },
    "main_stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "miroshark_section",
        "sep1",
        "aeon_section",
        "sep2",
        "stats_section",
        "sep3",
        "recap_link"
      ]
    },
    "miroshark_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "miroshark_heading",
        "miroshark_meta",
        "pr_link",
        "pr_details",
        "sep_inner1",
        "changes_heading",
        "change_1",
        "change_2",
        "change_3",
        "sep_inner2",
        "models_heading",
        "model_grid",
        "sep_inner3",
        "pricing_heading",
        "pricing_text",
        "pricing_stats"
      ]
    },
    "miroshark_heading": {
      "type": "Heading",
      "props": {
        "text": "aaronjmars/MiroShark",
        "level": "h2"
      }
    },
    "miroshark_meta": {
      "type": "Text",
      "props": {
        "text": "1 substantive commit by aaronjmars (9 automation commits filtered)",
        "variant": "caption"
      }
    },
    "pr_link": {
      "type": "StoryLink",
      "props": {
        "title": "Model Lineup Overhaul (PR #223)",
        "href": "https://github.com/aaronjmars/MiroShark/pull/223",
        "source": "MiroShark"
      }
    },
    "pr_details": {
      "type": "Text",
      "props": {
        "text": "Default Cloud preset replaced entirely. Base persona/sim-config slot moved from Xiaomi Mimo V2.5 to Inception Mercury 2 (diffusion LLM picked for raw speed). Wonderwall simulation loop (850+ calls/run) and web search slot both move to DeepSeek V4 Flash. Smart and NER stay on Gemini 3 Flash.",
        "variant": "body"
      }
    },
    "sep_inner1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "changes_heading": {
      "type": "Heading",
      "props": {
        "text": "Key Changes",
        "level": "h3"
      }
    },
    "change_1": {
      "type": "Text",
      "props": {
        "text": "config.py: All 4 model slots now carry explicit defaults instead of empty-string inherit — operators get per-slot defaults, set empty to inherit base",
        "variant": "body"
      }
    },
    "change_2": {
      "type": "Text",
      "props": {
        "text": "run_summary.py: Live OpenRouter pricing added for Mercury 2 ($0.25/$0.75) and DeepSeek V4 Flash ($0.098/$0.196)",
        "variant": "body"
      }
    },
    "change_3": {
      "type": "Text",
      "props": {
        "text": "12 files updated across config, settings preset, .env.example, docs (EN+ZH MODELS/INSTALL/CONFIGURATION), frontend SettingsPanel placeholder",
        "variant": "body"
      }
    },
    "sep_inner2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
