    "text_summary": {
      "type": "Text",
      "props": {
        "text": "Push-recap now detects same-day re-runs and suppresses duplicate notifications. When the skill runs a second time on the same day and finds the same commits already covered in the earlier article, it logs PUSH_RECAP_RERUN_QUIET and stops — no redundant notification, no article overwrite."
      }
    },
