    "text_why": {
      "type": "Text",
      "props": {
        "text": "Push-recap sent duplicate notifications on Jun 30 and Jul 1. The 24-hour commit window returned the same commits on re-runs, so the skill re-analyzed and re-notified with identical content. Repo-pulse already had this guard (REPO_PULSE_QUIET), push-recap did not."
      }
    },
