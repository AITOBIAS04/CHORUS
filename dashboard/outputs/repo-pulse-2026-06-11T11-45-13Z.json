{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse"
      },
      "children": [
        "repo-link",
        "sep1",
        "stats-stack",
        "sep2",
        "stargazers-section",
        "sep3",
        "forks-section"
      ]
    },
    "repo-link": {
      "type": "StoryLink",
      "props": {
        "title": "aaronjmars/MiroShark",
        "href": "https://github.com/aaronjmars/MiroShark"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stats-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "stars-stat",
        "forks-stat"
      ]
    },
    "stars-stat": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "1,248",
        "delta": "+4",
        "trend": "up"
      }
    },
    "forks-stat": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "264",
        "delta": "+1",
        "trend": "up"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stargazers-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "stargazers-heading",
        "stargazers-list"
      ]
    },
    "stargazers-heading": {
      "type": "Heading",
      "props": {
        "text": "New stargazers",
        "level": "h3"
      }
    },
    "stargazers-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "star-user-1",
        "star-user-2",
        "star-user-3",
        "star-user-4"
      ]
    },
    "star-user-1": {
      "type": "Link",
      "props": {
        "label": "AIRzZ90",
        "href": "https://github.com/AIRzZ90"
      }
    },
    "star-user-2": {
      "type": "Link",
      "props": {
        "label": "AmeanAF",
        "href": "https://github.com/AmeanAF"
      }
    },
    "star-user-3": {
      "type": "Link",
      "props": {
        "label": "nickarchuleta",
        "href": "https://github.com/nickarchuleta"
      }
    },
    "star-user-4": {
      "type": "Link",
      "props": {
        "label": "LeonardoRO",
        "href": "https://github.com/LeonardoRO"
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "forks-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "forks-heading",
        "forks-list"
      ]
    },
    "forks-heading": {
      "type": "Heading",
      "props": {
        "text": "New forks",
        "level": "h3"
      }
    },
    "forks-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "fork-user-1"
      ]
    },
    "fork-user-1": {
      "type": "Link",
      "props": {
        "label": "MiguelBits/MiroShark",
        "href": "https://github.com/MiguelBits/MiroShark"
      }
    }
  }
}
