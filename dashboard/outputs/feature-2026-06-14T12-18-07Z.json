        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "endpoint-heading",
        "endpoint-code",
        "endpoint-rationale",
        "endpoint-features"
      ]
    },
    "endpoint-heading": {
      "type": "Heading",
      "props": {
        "text": "Endpoint",
        "level": "h3"
      }
    },
    "endpoint-code": {
      "type": "Text",
      "props": {
        "text": "GET /api/simulation/search?q=interest+rates&limit=10",
        "variant": "lead"
      }
    },
    "endpoint-rationale": {
      "type": "Text",
      "props": {
        "text": "The gallery's built-in search works great for the /explore UI, but ecosystem partners building topic dashboards need a lightweight discovery primitive.",
