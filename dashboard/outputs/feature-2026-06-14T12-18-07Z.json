    "description-main": {
      "type": "Text",
      "props": {
        "text": "New standalone search endpoint for MiroShark. Searches both simulation titles and descriptions using case-insensitive matching, returns 120-char snippets with bold-wrapped matches, and sorts by newest first. Special characters like C++ and $MIROSHARK are handled safely via regex escaping.",
        "variant": "body"
      }
    },
    "sep-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "endpoint-section": {
