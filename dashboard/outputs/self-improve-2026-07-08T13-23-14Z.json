        "text_changed_details"
      ]
    },
    "heading_changed": {
      "type": "Heading",
      "props": {
        "text": "What changed",
        "level": "h3"
      }
    },
    "text_changed_details": {
      "type": "Text",
      "props": {
        "text": "skills/fetch-tweets/SKILL.md: Added 3-query cap to WebSearch fallback path with strategic query guidance (primary keyword, alternate terms, handle-based). Saves ~7-9 wasted tool calls per daily run while maintaining the same effective coverage."
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
