    "heading_problem": {
      "type": "Heading",
      "props": {
        "text": "Problem",
        "level": "h3"
      }
    },
    "text_problem_desc": {
      "type": "Text",
      "props": {
        "text": "fetch-tweets WebSearch fallback was burning 10-12 queries per run with zero results. Three consecutive days of FETCH_TWEETS_EMPTY (Jul 6-8) — WebSearch returns only older tweets from March-May, and additional query variations beyond the first few have near-zero marginal return."
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stack_why": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading_why",
        "text_why_desc"
      ]
    },
    "heading_why": {
      "type": "Heading",
      "props": {
        "text": "Why",
        "level": "h3"
      }
    },
    "text_why_desc": {
      "type": "Text",
      "props": {
        "text": "Observed 10x and 12x WebSearch attempts in Jul 7 and Jul 8 logs respectively, all returning nothing new. The skill was spending significant compute trying different phrasings of the same failed search."
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stack_changed": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
