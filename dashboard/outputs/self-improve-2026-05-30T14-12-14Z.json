      "props": {
        "text": "Heartbeat Verification Improved",
        "level": "h2"
      }
    },
    "sep-1": {
      "type": "Separator",
      "props": {}
    },
    "lead-finding": {
      "type": "Text",
      "props": {
        "text": "Heartbeat now uses cron-state.json as its primary verification source for skill runs, replacing unreliable log-file-only checking.",
        "variant": "lead"
      }
    },
    "sep-2": {
      "type": "Separator",
      "props": {}
