      "children": [
        "prob-p1",
        "prob-p2",
        "prob-p3",
        "prob-skills"
      ]
    },
    "prob-p1": {
      "type": "Text",
      "props": {
        "text": "The heartbeat skill was checking only daily log files to determine if skills ran — causing persistent false positives. Skills that ran successfully (confirmed in cron-state.json) but logged under different names or skipped log entries were flagged as \"missing.\""
      }
    },
    "prob-p2": {
      "type": "Text",
      "props": {
        "text": "A stale memory lesson incorrectly claimed \"PR #47 disabled 5 skills\" — but PR #47 does not exist in this repo."
      }
    },
    "prob-p3": {
      "type": "Text",
      "props": {
        "text": "Heartbeat reports from May 27-29 each contained noise about \"chronic skips\" and \"disabled by PR #47\" for three skills that cron-state.json proved were running fine:"
      }
    },
    "prob-skills": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "sm"
      },
      "children": [
        "skill-1",
        "skill-2",
        "skill-3"
      ]
    },
    "skill-1": {
      "type": "Badge",
