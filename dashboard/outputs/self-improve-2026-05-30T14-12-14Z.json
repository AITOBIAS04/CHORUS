    },
    "impact-heading": {
      "type": "Heading",
      "props": {
        "text": "Impact",
        "level": "h3"
      }
    },
    "impact-text": {
      "type": "Text",
      "props": {
        "text": "Heartbeat reports will be cleaner — no more false-positive \"missing\" flags for skills that actually ran. The 3-step hierarchy ensures the most authoritative source is checked first."
      }
    },
    "sep-5": {
      "type": "Separator",
      "props": {}
