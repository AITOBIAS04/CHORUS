    "stat-lines": {
      "type": "Stat",
      "props": {
        "label": "Lines",
        "value": "+1 / -1"
      }
    },
    "sep-3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "recap-link": {
      "type": "Link",
      "props": {
        "label": "Full recap",
        "href": "https://github.com/AITOBIAS04/CHORUS/blob/main/articles/push-recap-2026-07-08.md"
