      "type": "Card",
      "props": {
        "title": "Push Recap — 2026-07-08"
      },
      "children": [
        "stack-main"
      ]
    },
    "stack-main": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "header-stack",
        "sep-1",
        "change-stack",
        "sep-2",
        "stats-stack",
        "sep-3",
        "recap-link"
      ]
