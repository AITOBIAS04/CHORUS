        "text": "Ecosystem Maintenance: RootAI profile image updated in ECOSYSTEM.md",
        "level": "h3"
      }
    },
    "change-desc": {
      "type": "Text",
      "props": {
        "text": "The Twitter/X avatar CDN URL was swapped to reflect RootAI's current branding. No code or functional changes — just keeping the partner directory visually accurate.",
        "variant": "body"
      }
    },
    "key-changes-label": {
      "type": "Text",
      "props": {
        "text": "Key changes:",
        "variant": "lead"
      }
    },
    "change-detail": {
      "type": "Text",
      "props": {
        "text": "Updated RootAI (<img src>) URL in ECOSYSTEM.md ecosystem partner table (+1/-1 lines)",
        "variant": "caption"
      }
    },
    "pr-link": {
      "type": "Link",
      "props": {
        "label": "#242",
        "href": "https://github.com/AITOBIAS04/CHORUS/pull/242"
      }
    },
    "sep-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stats-stack": {
      "type": "Stack",
      "props": {
