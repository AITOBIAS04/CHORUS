      "children": [
        "repo-badge",
        "author-badge",
        "commits-badge"
      ]
    },
    "repo-badge": {
      "type": "Badge",
      "props": {
        "text": "MiroShark",
        "variant": "default"
      }
    },
    "author-badge": {
      "type": "Badge",
      "props": {
        "text": "@aaronjmars",
        "variant": "secondary"
      }
    },
    "commits-badge": {
      "type": "Badge",
      "props": {
        "text": "1 substantive (12 automation filtered)",
        "variant": "outline"
      }
    },
