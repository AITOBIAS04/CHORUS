    "text_pr152_main": {
      "type": "Text",
      "props": {
        "text": "MiroShark shipped its first cryptographic verifiability primitive. GET /api/simulation/<id>/signed-result.json wraps the signal.json payload in an HMAC-SHA256-signed envelope using the existing WEBHOOK_SECRET — integrators can now prove a stored result was not tampered with, offline, without calling back to the API."
      }
    },
    "text_pr152_details1": {
      "type": "Text",
      "props": {
        "text": "The 34th catalogued surface, +1,051 lines, 25 tests, zero new deps (42-PR streak).",
