        "text": "Why",
        "level": "h3"
      }
    },
    "text_why_context": {
      "type": "Text",
      "props": {
        "text": "On Jul 22, self-improve ran twice and created two identical PRs (#38 and #39) — both titled \"improve: add same-day rerun dedup to repo-article skill.\" The second run implemented the same change that was already in an open PR, wasting a full skill execution.",
        "variant": "body"
      }
    },
    "sep_2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "heading_what": {
