        "level": "h3"
      }
    },
    "text_what_details": {
      "type": "Text",
      "props": {
        "text": "skills/self-improve/SKILL.md: added Step 2.5 — queries open improve: PRs before implementation begins; logs SELF_IMPROVE_DEDUP and stops if a duplicate is found",
        "variant": "body"
      }
    },
    "sep_3": {
      "type": "Separator",
