    },
    "heading_coordination": {
      "type": "Heading",
      "props": {
        "text": "The coordination play",
        "level": "h3"
      }
    },
    "text_coordination_1": {
      "type": "Text",
      "props": {
        "text": "MiroShark has 1,358 stars, 288 forks, and named contributors (aaronjmars, Daniel Andersen, Zarbel974) — but every single interaction has been asynchronous. PRs, commits, GitHub issues. Zero live conversation, ever."
      }
    },
    "text_coordination_2": {
      "type": "Text",
      "props": {
        "text": "Someone needs to schedule a Space, invite speakers, and show up. The market is the scheduling pressure — its existence turns \"we should do a call sometime\" into \"who is booking the room?\""
      }
    },
    "grid_miroshark_stats": {
      "type": "Grid",
      "props": {
        "columns": 2,
