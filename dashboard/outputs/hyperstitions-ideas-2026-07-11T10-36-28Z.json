    "heading_main": {
      "type": "Heading",
      "props": {
        "text": "Will MiroShark hold its first public community call or Twitter Space with 3+ distinct speakers by September 1, 2026?",
        "level": "h2"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
